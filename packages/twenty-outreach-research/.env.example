# Twenty CRM
TWENTY_API_URL=http://localhost:3000
TWENTY_API_KEY=replace_me_with_api_key_from_settings

# LLMs — at least one of these (matching your role models below) must be set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Free / cheap providers (OpenAI-compatible). Pick whichever you want to use:
#   NVIDIA NIM — free hosted Llama / Kimi K2 / Nemotron / Mixtral / DeepSeek
#                Sign up at https://build.nvidia.com to get a key.
NVIDIA_API_KEY=
#   OpenRouter — one key, every model. Kimi K2 + GPT + Claude + everything else.
OPENROUTER_API_KEY=
#   Moonshot direct (Kimi) — international endpoint. Requires Moonshot account.
MOONSHOT_API_KEY=
#   Groq — fastest open-model inference. Kimi K2 + Llama + Mixtral.
GROQ_API_KEY=

# Optional per-role model overrides. Format: "provider:model".
# Defaults (when these are unset):
#   extractor   → nvidia:meta/llama-3.3-70b-instruct    (free, fast extraction)
#   synthesizer → anthropic:claude-sonnet-4-6           (best multi-source synth)
#   writer      → anthropic:claude-opus-4-7             (best prose, peer voice)
#   critic      → anthropic:claude-opus-4-7             (same model as writer for self-critique)
#   judge       → nvidia:moonshotai/kimi-k2.6           (independent family, free)
#
# IMPORTANT — structured-output reliability:
#   Anthropic + OpenAI use native structured-output paths and are reliable.
#   openai-compatible providers (nvidia, openrouter, moonshot, groq) use a
#   forced tool-call coercion path in our router. Kimi K2.6 on NIM is
#   *intermittent* for the writer role on complex schemas — the router
#   auto-retries once with a stronger directive. If you need reliable Kimi
#   behavior, prefer Groq:
#     WRITER_MODEL=groq:moonshotai/kimi-k2-instruct  (needs GROQ_API_KEY)
#
# Override examples:
# EXTRACTOR_MODEL=nvidia:meta/llama-3.3-70b-instruct
# SYNTHESIZER_MODEL=anthropic:claude-sonnet-4-6
# WRITER_MODEL=anthropic:claude-opus-4-7
# CRITIC_MODEL=anthropic:claude-opus-4-7
# JUDGE_MODEL=openai:gpt-5

# Research / scraping
EXA_SEARCH_API_KEY=
FIRECRAWL_API_KEY=
PERPLEXITY_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=

# Contact enrichment
APOLLO_API_KEY=
HUNTER_API_KEY=

# Gmail (OAuth client; user-level tokens stored per-user via Twenty's existing Google OAuth flow)
# Reuses Twenty's AUTH_GOOGLE_CLIENT_ID/_SECRET when set; falls back to GOOGLE_OAUTH_*.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
#   Run `yarn auth:gmail` once to mint this refresh token. Store the printed
#   value in Doppler. Scopes: gmail.compose + gmail.modify.
GMAIL_REFRESH_TOKEN=

# Redis (for BullMQ queueing). Reuses Twenty's Redis. Defaults to redis://localhost:6379.
REDIS_URL=

# Notion (for ongoing RAG over the playbook docs; the one-time backfill
# of the Customer Outreach DB is handled by /Users/mats2/Documents/GTM/migration)
NOTION_API_KEY=

# Behavior
OUTREACH_DEFAULT_OWNER_EMAIL=mateo.sanchezlopeznegrete@yale.edu
OUTREACH_DRY_RUN=true
